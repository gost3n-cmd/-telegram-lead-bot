# Telegram Lead-Capture Bot — Configuration
# Copy this file to .env and fill in the values

# REQUIRED: Telegram Bot API token
BOT_TOKEN=

# OPTIONAL: Path to the shared Excel file (relative to working directory)
EXCEL_FILE_PATH=data/ai_content_os.xlsx

# OPTIONAL: Name of the Leads sheet in the Excel workbook
# WARNING: Must NOT match any of the 11 OWNED_SHEETS in build_system.py!
LEADS_SHEET_NAME=Leads

# OPTIONAL: Logging level (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# OPTIONAL: Environment (production / development)
ENVIRONMENT=development

# OPTIONAL: Google Sheets live dashboard (secondary output)
# Leave both empty to run in Excel-only mode (no change from current behaviour).
# GOOGLE_SHEET_ID — the long string from the Google Sheets URL after /d/
# GOOGLE_CREDENTIALS_PATH — path to the service-account JSON file (e.g. gsheets-creds.json)
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=
